# Copy to .env and fill in. .env is gitignored.

# Postgres / Supabase connection string.
# Supabase: Project Settings -> Database -> Connection string -> "Session pooler".
# Local dev example: postgresql://postgres:postgres@localhost:5432/worldcup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worldcup

# Run the browser headless (true) or visible (false) for debugging.
WC_HEADLESS=true

# Seconds to wait politely between page navigations.
WC_REQUEST_DELAY=1.5

# Directory for cached rendered HTML (so re-runs don't re-hit ESPN).
WC_CACHE_DIR=.cache
